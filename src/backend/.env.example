APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/valore365

FINANCE_PROVIDER=yfinance
# Le seguenti variabili sono necessarie solo se si usa TwelveData come provider
# FINANCE_API_BASE_URL=https://api.twelvedata.com/
# FINANCE_API_KEY=replace-with-your-key
# FINANCE_REQUEST_TIMEOUT_SECONDS=10
# FINANCE_MAX_RETRIES=3
# FINANCE_RETRY_BACKOFF_SECONDS=0.5
# FINANCE_SYMBOL_REQUEST_DELAY_SECONDS=0.2

PRICE_SCHEDULER_ENABLED=false
PRICE_SCHEDULER_INTERVAL_SECONDS=60
PRICE_SCHEDULER_PORTFOLIO_ID=

CLERK_AUTH_ENABLED=false
CLERK_JWKS_URL=
CLERK_AUTHORIZED_PARTIES=

CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Portfolio Copilot (AI assistant) ---
# Provider: "openai" | "anthropic" | "gemini"
COPILOT_PROVIDER=openai
# API key del provider scelto (serve solo quella del provider attivo)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Modello (opzionale, lasciare vuoto per il default del provider)
# Default: openai=gpt-4o-mini, anthropic=claude-sonnet-4-20250514, gemini=gemini-2.0-flash
COPILOT_MODEL=
