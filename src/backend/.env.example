APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/valore365

FINANCE_PROVIDER=yfinance
FINANCE_API_BASE_URL=
FINANCE_API_KEY=
FINANCE_REQUEST_TIMEOUT_SECONDS=10
FINANCE_MAX_RETRIES=3
FINANCE_RETRY_BACKOFF_SECONDS=0.5
FINANCE_SYMBOL_REQUEST_DELAY_SECONDS=0

PRICE_SCHEDULER_ENABLED=false
PRICE_SCHEDULER_INTERVAL_SECONDS=60
PRICE_SCHEDULER_PORTFOLIO_ID=

PAC_SCHEDULER_ENABLED=false
PAC_EXECUTION_HOUR=8

CLERK_AUTH_ENABLED=false
CLERK_JWKS_URL=
CLERK_AUTHORIZED_PARTIES=

# Admin access: prefer user ids, email allowlist can be used as a pragmatic fallback.
ADMIN_USER_IDS=
# Your clerk account
ADMIN_EMAILS=

# Reverse proxy / frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173
TRUSTED_PROXY_IPS=

# Public instant analyzer hardening
PUBLIC_INSTANT_ANALYZER_RATE_LIMIT_REQUESTS=10
PUBLIC_INSTANT_ANALYZER_RATE_LIMIT_WINDOW_SECONDS=60
PUBLIC_INSTANT_ANALYZER_MAX_POSITIONS=50
PUBLIC_INSTANT_ANALYZER_MAX_RAW_TEXT_CHARS=5000
PUBLIC_INSTANT_ANALYZER_MAX_LINE_LENGTH=128

# CSV import hardening
CSV_IMPORT_MAX_UPLOAD_BYTES=5242880

# Feature flags
ENABLE_TARGET_ALLOCATION=true

# Copilot
COPILOT_PROVIDER=
COPILOT_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
COPILOT_LOCAL_URL=http://localhost:11434/v1
COPILOT_LOCAL_API_KEY=not-needed
COPILOT_ENCRYPTION_KEY=

# Price validation thresholds
PRICE_VALIDATION_MIN_PRICE=0.0001
PRICE_VALIDATION_MAX_DAILY_CHANGE_PCT=50
PRICE_VALIDATION_MAX_OHLC_SPREAD_PCT=100
PRICE_VALIDATION_STALE_DAYS=5
PRICE_VALIDATION_FX_MIN_RATE=0.0001
PRICE_VALIDATION_FX_MAX_RATE=10000
